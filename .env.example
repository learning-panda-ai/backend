##################################################
# Environment Variables                         #
##################################################

# Application settings
APP_NAME=LearningPanda
DEBUG=True

# CORS settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── JWT ─────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/learningpanda

# ── AWS ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# S3 — file storage
S3_BUCKET_NAME=your-s3-bucket-name
S3_KEY_PREFIX=uploads
MAX_UPLOAD_SIZE_MB=10

# SES — transactional email (must be a verified SES sender identity)
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=Learning Panda

# ── Google OAuth ─────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match an authorised redirect URI in your Google Cloud console
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── Frontend ─────────────────────────────────────
# After OAuth / magic-link sign-in the backend redirects here
FRONTEND_URL=http://localhost:3000

# ── Cookie security ───────────────────────────────
# Set True in production (requires HTTPS)
COOKIE_SECURE=False

# ── OTP ──────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_RATE_LIMIT_COUNT=3
OTP_RATE_LIMIT_WINDOW_MINUTES=15

# ── Redis ────────────────────────────────────────
# Celery broker and result backend
REDIS_URL=redis://localhost:6379/0

# ── Milvus ───────────────────────────────────────
MILVUS_URI=http://localhost:19530

# ── Gemini API settings ──────────────────────────
GOOGLE_API_KEY=your-google-api-key
GOOGLE_AGENT=gemini-2.5-flash
